    "Add a card in Tesserone" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Füge in Tesserone eine Karte hinzu" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Añade una tarjeta en Tesserone" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ajoute une carte dans Tesserone" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Aggiungi una tessera in Tesserone" } }
      }
    },
