    "Show a set of loyalty cards; tap one to open it." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zeigt mehrere Karten; tippe eine an, um sie zu öffnen." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Muestra un conjunto de tarjetas; toca una para abrirla." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Affiche un ensemble de cartes ; touche-en une pour l’ouvrir." } },
