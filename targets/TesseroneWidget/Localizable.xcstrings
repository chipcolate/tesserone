    },
    "Choose which card this widget opens." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wähle, welche Karte dieses Widget öffnet." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Elige qué tarjeta abre este widget." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Choisis la carte que ce widget ouvre." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Scegli quale tessera apre questo widget." } }
      }
    },
    "Choose which cards this widget shows." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wähle, welche Karten dieses Widget anzeigt." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Elige qué tarjetas muestra este widget." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Choisis les cartes que ce widget affiche." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Scegli quali tessere mostra questo widget." } }
      }
    },
    "Open a loyalty card straight from your home screen." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Öffne eine Kundenkarte direkt vom Homescreen." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Abre una tarjeta de fidelidad directamente desde la pantalla de inicio." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Ouvre une carte de fidélité directement depuis l’écran d’accueil." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Apri una tessera fedeltà direttamente dalla schermata Home." } }
      }
    },
