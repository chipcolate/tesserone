{
  "expo": {
    "name": "Tesserone",
    "slug": "tesserone",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tesserone",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chipcolate.tesserone",
      "appleTeamId": "HNF5BY9XXV",
      "buildNumber": "16",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleLocalizations": ["en", "it", "fr", "es", "de"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "package": "com.chipcolate.tesserone",
      "versionCode": 16,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-system-ui",
        {
          "backgroundColor": "#0A0A0A"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Tesserone needs camera access to scan barcodes on your loyalty cards.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-brightness",
        {
          "isSystemBrightnessAllowed": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Tesserone uses your photo library so you can pick a custom logo for a card.",
          "microphonePermission": false
        }
      ],
      "expo-sharing",
      "expo-image",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsImageWithMaxCount": 1
          },
          "androidIntentFilters": [
            "image/*"
          ]
        }
      ],
      "@bacons/apple-targets",
      "expo-font",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "SingleCard",
              "label": "@string/widget_singlecard_label",
              "description": "Open a loyalty card straight from your home screen.",
              "minWidth": "40dp",
              "minHeight": "40dp",
              "targetCellWidth": 1,
              "targetCellHeight": 1,
              "resizeMode": "none",
              "previewImage": "./assets/widget-single-preview.png",
              "widgetFeatures": "reconfigurable"
            },
            {
              "name": "CardList",
              "label": "@string/widget_cardlist_label",
              "description": "Show a set of loyalty cards; tap one to open it.",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "maxResizeWidth": "320dp",
              "maxResizeHeight": "320dp",
              "resizeMode": "horizontal|vertical",
              "previewImage": "./assets/widget-list-preview.png",
              "widgetFeatures": "reconfigurable"
            }
          ]
        }
      ],
      "./plugins/withWidgetStrings",
      "./plugins/withWidgetDeepLinkIntent"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be2e28e5-6dae-42f0-99f0-6c92da02a69d"
      }
    },
    "owner": "chipcolate"
  }
}
