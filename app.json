{
  "expo": {
    "name": "Tesserone",
    "slug": "tesserone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tesserone",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chipcolate.tesserone",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.chipcolate.tesserone",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-system-ui",
        {
          "backgroundColor": "#0A0A0A"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Tesserone needs camera access to scan barcodes on your loyalty cards.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-brightness",
        {
          "isSystemBrightnessAllowed": true
        }
      ],
      "expo-sharing",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "be2e28e5-6dae-42f0-99f0-6c92da02a69d"
      }
    },
    "owner": "chipcolate"
  }
}
