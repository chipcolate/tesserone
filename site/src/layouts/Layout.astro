---
import "../styles/global.css";
import {
  DEFAULT_LOCALE,
  SITE_LOCALES,
  getStrings,
  localeUrl,
  type Locale,
} from "../i18n";

interface Props {
  lang: Locale;
  path?: string;
  title?: string;
  description?: string;
}

const { lang, path = "", title, description } = Astro.props;
const s = getStrings(lang);

const resolvedTitle = title ?? s.meta.defaultTitle;
const resolvedDescription = description ?? s.meta.defaultDescription;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={s.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonical} />
    {
      SITE_LOCALES.map((loc) => (
        <link
          rel="alternate"
          hreflang={loc}
          href={new URL(
            localeUrl(baseUrl, loc, path),
            Astro.site,
          ).toString()}
        />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(
        localeUrl(baseUrl, DEFAULT_LOCALE, path),
        Astro.site,
      ).toString()}
    />
    <link rel="icon" href={`${baseUrl}favicon.ico`} sizes="any" />
    <link rel="apple-touch-icon" href={`${baseUrl}apple-touch-icon.png`} />
    <link rel="manifest" href={`${baseUrl}manifest.webmanifest`} />
    <meta name="theme-color" content="#6C2DD7" />
    <meta name="apple-mobile-web-app-title" content="Tesserone" />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={s.htmlLang} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{resolvedTitle}</title>
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("tesserone-theme");
          const prefersDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          const dark = stored ? stored === "dark" : prefersDark;
          document.documentElement.classList.toggle("dark", dark);
        } catch {}
      })();
    </script>
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>
