---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<footer
  class="border-t border-[var(--color-border)] px-6 py-12 text-sm text-[var(--color-fg-muted)]"
>
  <div
    class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-6 sm:flex-row sm:items-center"
  >
    <p>
      &copy; {year}
      <a
        href="https://chipcolate.com"
        class="font-medium text-[var(--color-fg)] hover:text-[var(--color-accent)]"
        >Chipcolate</a
      >. Apache 2.0 licensed.
    </p>
    <nav class="flex flex-wrap gap-6">
      <a
        href={`${base}/privacy`}
        class="hover:text-[var(--color-accent)]">Privacy</a
      >
      <a
        href="https://github.com/chipcolate/tesserone"
        class="hover:text-[var(--color-accent)]">GitHub</a
      >
      <a
        href="https://github.com/chipcolate/tesserone/issues"
        class="hover:text-[var(--color-accent)]">Issues</a
      >
    </nav>
  </div>
</footer>
