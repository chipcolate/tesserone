---
import StoreCTAs from "./StoreCTAs.astro";
import { getStrings, type Locale } from "../i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const s = getStrings(lang).hero;

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="px-6 pt-12 pb-12 sm:pt-16 sm:pb-16 lg:pt-24">
  <div class="mx-auto grid max-w-6xl gap-16 lg:grid-cols-2 lg:items-center">
    <div>
      <div class="flex items-center gap-5 lg:block">
        <div class="min-w-0 flex-1 lg:flex-none">
          <p
            class="mb-4 text-sm font-medium tracking-widest text-[var(--color-accent)] uppercase"
          >
            {s.eyebrow}
          </p>
          <h1
            class="text-5xl font-extrabold tracking-tight text-balance sm:text-6xl lg:text-7xl"
          >
            {s.headlineLine1}<br />
            <span class="text-[var(--color-fg-muted)]">{s.headlineLine2}</span>
            <span class="text-[var(--color-accent)]">{s.headlineLine3}</span>
          </h1>
        </div>

        <div class="w-28 shrink-0 sm:w-36 lg:hidden" aria-hidden="true">
          <img src={`${base}hero-icon-light.svg`} alt="" class="w-full" />
        </div>
      </div>

      <p
        class="mt-6 max-w-xl text-lg leading-relaxed text-[var(--color-fg-muted)] text-pretty sm:text-xl"
      >
        {s.subheading}
      </p>
      <div class="mt-10">
        <StoreCTAs lang={lang} />
      </div>
    </div>

    <div class="hidden lg:block" aria-hidden="true">
      <div class="mx-auto w-80">
        <img src={`${base}hero-icon-light.svg`} alt="" class="w-full" />
      </div>
    </div>
  </div>
</section>
