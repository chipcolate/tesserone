---
import StoreCTAs from "./StoreCTAs.astro";
---

<section
  class="relative overflow-hidden px-6 pt-12 pb-12 sm:pt-16 sm:pb-16 lg:pt-24"
>
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-b from-[var(--color-accent)]/10 via-transparent to-transparent"
  >
  </div>

  <div class="mx-auto grid max-w-6xl gap-16 lg:grid-cols-2 lg:items-center">
    <div>
      <div class="flex items-center gap-5 lg:block">
        <div class="min-w-0 flex-1 lg:flex-none">
          <p
            class="mb-4 text-sm font-medium tracking-widest text-[var(--color-accent)] uppercase"
          >
            Tesserone
          </p>
          <h1
            class="text-5xl font-bold tracking-tight text-balance sm:text-6xl lg:text-7xl"
          >
            Your loyalty cards.<br />
            <span class="text-[var(--color-fg-muted)]">On your phone.</span>
            <span class="text-[var(--color-accent)]">That's it.</span>
          </h1>
        </div>

        <div
          class="relative w-28 shrink-0 sm:w-36 lg:hidden"
          aria-hidden="true"
        >
          <div
            class="absolute inset-0 -z-10 rounded-[2rem] bg-gradient-to-br from-[var(--color-accent)]/20 to-transparent blur-2xl"
          >
          </div>
          <div class="relative aspect-[9/19] w-full">
            <div
              class="absolute inset-0 rotate-[-6deg] rounded-[1.5rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] shadow-2xl"
            >
              <div class="flex h-full flex-col gap-1.5 p-2 pt-5 sm:gap-2 sm:p-3 sm:pt-7">
                <div
                  class="min-h-0 flex-1 rounded-lg bg-gradient-to-br from-rose-500 to-red-600"
                >
                </div>
                <div
                  class="min-h-0 flex-1 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-600"
                >
                </div>
                <div
                  class="min-h-0 flex-1 rounded-lg bg-gradient-to-br from-blue-500 to-indigo-600"
                >
                </div>
                <div
                  class="min-h-0 flex-1 rounded-lg bg-gradient-to-br from-amber-500 to-orange-600"
                >
                </div>
                <div
                  class="min-h-0 flex-1 rounded-lg bg-gradient-to-br from-violet-500 to-purple-600"
                >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <p
        class="mt-6 max-w-xl text-lg leading-relaxed text-[var(--color-fg-muted)] text-pretty sm:text-xl"
      >
        A simple loyalty card manager with a familiar card-stack feel. No
        cloud, no accounts, no tracking. Your cards live on your device — where
        they belong.
      </p>
      <div class="mt-10">
        <StoreCTAs />
      </div>
    </div>

    <div class="relative hidden lg:block" aria-hidden="true">
      <div
        class="absolute inset-0 -z-10 rounded-[3rem] bg-gradient-to-br from-[var(--color-accent)]/20 to-transparent blur-3xl"
      >
      </div>
      <div class="relative mx-auto aspect-[9/19] w-64">
        <div
          class="absolute inset-0 rotate-[-6deg] rounded-[2.5rem] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] shadow-2xl"
        >
          <div class="flex h-full flex-col gap-3 p-4 pt-12">
            <div
              class="h-24 rounded-2xl bg-gradient-to-br from-rose-500 to-red-600"
            >
            </div>
            <div
              class="h-24 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600"
            >
            </div>
            <div
              class="h-24 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600"
            >
            </div>
            <div
              class="h-24 rounded-2xl bg-gradient-to-br from-amber-500 to-orange-600"
            >
            </div>
            <div
              class="h-24 rounded-2xl bg-gradient-to-br from-violet-500 to-purple-600"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
