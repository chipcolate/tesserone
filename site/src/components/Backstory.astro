---
import { getStrings, type Locale } from "../i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const s = getStrings(lang).backstory;
---

<section id="backstory" class="px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-3xl">
    <p
      class="mb-4 text-sm font-medium tracking-widest text-[var(--color-accent)] uppercase"
    >
      {s.eyebrow}
    </p>
    <h2 class="mb-10 text-3xl font-bold tracking-tight sm:text-4xl">
      {s.headingLine1}<br />
      <span class="text-[var(--color-fg-muted)]">{s.headingLine2}</span>
    </h2>

    <div
      class="prose prose-lg space-y-6 text-lg leading-relaxed text-[var(--color-fg-muted)]"
    >
      <p>{s.p1}</p>
      <p>{s.p2}</p>
      <p>{s.p3}</p>
      <p class="font-medium text-[var(--color-fg)]">{s.p4}</p>
    </div>
  </div>
</section>
