---
import StoreCTAs from "./StoreCTAs.astro";

const repoUrl = "https://github.com/chipcolate/tesserone";
---

<section id="open-source" class="px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-4xl">
    <div
      class="rounded-3xl border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-10 sm:p-16"
    >
      <p
        class="mb-4 text-sm font-medium tracking-widest text-[var(--color-accent)] uppercase"
      >
        Open source, simple by design
      </p>
      <h2 class="mb-6 text-3xl font-bold tracking-tight sm:text-4xl">
        Every line, auditable.
      </h2>
      <p
        class="mb-8 max-w-2xl text-lg leading-relaxed text-[var(--color-fg-muted)]"
      >
        Tesserone is released under the Apache 2.0 licence. That means you can
        read it, audit it, fork it, or build your own. No telemetry, no
        analytics, no servers — and nothing to take our word on.
      </p>

      <div class="mb-10 flex flex-wrap items-center gap-3">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-2 text-sm font-medium"
        >
          <svg
            class="h-4 w-4 text-[var(--color-accent)]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M9 12l2 2 4-4"></path>
            <circle cx="12" cy="12" r="10"></circle>
          </svg>
          Apache 2.0 Licence
        </span>
        <span
          class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-2 text-sm font-medium"
        >
          <svg
            class="h-4 w-4 text-[var(--color-accent)]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M18.36 6.64A9 9 0 1 1 5.64 6.64"></path>
            <line x1="12" y1="2" x2="12" y2="12"></line>
          </svg>
          Zero telemetry
        </span>
        <span
          class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-2 text-sm font-medium"
        >
          <svg
            class="h-4 w-4 text-[var(--color-accent)]"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M2 12a10 10 0 1 0 20 0 10 10 0 0 0-20 0z"></path>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10"></path>
            <line x1="4" y1="4" x2="20" y2="20"></line>
          </svg>
          No servers
        </span>
      </div>

      <div class="flex flex-wrap items-center gap-4">
        <a
          href={repoUrl}
          class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-5 py-3 font-medium transition hover:border-[var(--color-accent)]"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.2 11.39.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.42-4.04-1.42-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.83 1.24 1.83 1.24 1.07 1.83 2.8 1.3 3.49.99.1-.77.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.23-3.22-.12-.3-.54-1.52.12-3.17 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.3-1.55 3.3-1.23 3.3-1.23.66 1.65.24 2.87.12 3.17.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.62-5.48 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.22.7.82.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"
            ></path>
          </svg>
          View on GitHub
        </a>
        <StoreCTAs variant="secondary" />
      </div>
    </div>
  </div>
</section>
