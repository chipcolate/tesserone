---
import { getStrings, type Locale } from "../i18n";

interface Props {
  variant?: "primary" | "secondary";
  lang: Locale;
}

const { variant = "primary", lang } = Astro.props;
const s = getStrings(lang).stores;

const appStoreUrl = "https://apps.apple.com/app/tesserone/id6762666621";
const playStoreUrl = "#";

const base =
  "inline-flex items-center gap-3 rounded-xl px-5 py-3 font-medium transition";
const primary =
  "bg-[var(--color-fg)] text-[var(--color-bg)] hover:bg-[var(--color-accent)] hover:text-black";
const secondary =
  "border border-[var(--color-border)] bg-[var(--color-bg-elevated)] text-[var(--color-fg)] hover:border-[var(--color-accent)]";
const cls = `${base} ${variant === "primary" ? primary : secondary}`;
---

<div class="flex flex-wrap items-center gap-3">
  <a href={appStoreUrl} class={cls} aria-label={s.appleAria}>
    <svg
      class="h-6 w-6"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"
      ></path>
    </svg>
    <span class="flex flex-col text-left leading-tight">
      <span class="text-xs opacity-80">{s.appleSup}</span>
      <span class="text-base font-semibold">{s.appleMain}</span>
    </span>
  </a>

  <a href={playStoreUrl} class={cls} aria-label={s.googleAria}>
    <svg
      class="h-6 w-6"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M3.6 2.8c-.37.4-.6.99-.6 1.76v15c0 .77.23 1.36.6 1.76l.1.09 8.4-8.41v-.2L3.7 2.7l-.1.1zm11.4 11l-2.8-2.8V10.9l2.8-2.8.06.04 3.32 1.89c.95.54.95 1.42 0 1.96l-3.32 1.88-.06.05zM12 12.6l-8.3 8.3c.31.33.83.37 1.42.04l9.73-5.52L12 12.6zm2.85-2.85L5.12 4.23C4.53 3.9 4.01 3.94 3.7 4.27L12 12.6l2.85-2.85z"
      ></path>
    </svg>
    <span class="flex flex-col text-left leading-tight">
      <span class="text-xs opacity-80">{s.googleSup}</span>
      <span class="text-base font-semibold">{s.googleMain}</span>
    </span>
  </a>
</div>
