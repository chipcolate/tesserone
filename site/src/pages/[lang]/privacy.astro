---
import Layout from "../../layouts/Layout.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import Footer from "../../components/Footer.astro";
import { getStrings, localeUrl, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { lang: "it" } },
    { params: { lang: "fr" } },
    { params: { lang: "es" } },
    { params: { lang: "de" } },
  ];
}

const { lang } = Astro.params as { lang: Locale };
const strings = getStrings(lang);
const s = strings.privacy;
const baseUrl = import.meta.env.BASE_URL;
const backHref = localeUrl(baseUrl, lang, "");

const sectionOrder = [
  "oneSentence",
  "whatWeCollect",
  "whatAppStores",
  "permissions",
  "thirdParties",
  "children",
  "rights",
  "changes",
  "contact",
] as const;
---

<Layout lang={lang} path="privacy" title={strings.meta.privacyTitle} description={strings.meta.privacyDescription}>
  <ThemeToggle lang={lang} />
  <main class="px-6 py-24 sm:py-32">
    <article class="mx-auto max-w-3xl">
      <a
        href={backHref}
        class="mb-8 inline-block text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)]"
        >{s.back}</a
      >

      <h1 class="mb-2 text-4xl font-bold tracking-tight sm:text-5xl">
        {s.title}
      </h1>
      <p class="mb-12 text-sm text-[var(--color-fg-muted)]">
        {s.effectiveDateLabel}: {s.effectiveDate}
      </p>

      <div class="space-y-10 text-lg leading-relaxed">
        {
          sectionOrder.map((key) => (
            <section>
              <h2 class="mb-4 text-2xl font-semibold">{s.sections[key].title}</h2>
              <div set:html={s.sections[key].body} />
            </section>
          ))
        }
      </div>
    </article>
  </main>
  <Footer lang={lang} path="privacy" />
</Layout>
